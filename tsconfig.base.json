{
    "compilerOptions": {
        "module": "ESNext",
        "declaration": true,
        "emitDeclarationOnly": true,
        "allowImportingTsExtensions": true,
        "target": "ES2020",
        "lib": ["ES2020", "DOM"],
        "useDefineForClassFields": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "baseUrl": "./src",
        "paths": {
            "@meshagent/meshagent-agents": ["../../meshagent-agents-ts/dist/node/index.d.ts"]
        },
        "rootDir": "./src",
        "typeRoots": [
            "./types",
            "./node_modules/@types",
            "../node_modules/@types"
        ]
    },
    "exclude": [
        "dist",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/test"
    ],
    "include": [
        "src"
    ]
}
